generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Auth (NextAuth.js / Auth.js)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// System Settings (key-value)
// ============================================

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ============================================
// Users & Members
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  phone         String?
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(MEMBER)
  status        UserStatus @default(ACTIVE)
  shopId        String?   @unique
  /// Cached AI credit balance. Authoritative source is sum(CreditTransaction.amount).
  /// Kept in sync by src/lib/credits.ts — never write outside that module.
  credits       Int       @default(0)
  /// Timestamp of last monthly auto-grant (for paid plans). Null = never granted.
  lastMonthlyGrantAt DateTime?
  /// Persistent UI language preference. Synced with the NEXT_LOCALE cookie:
  /// when the user changes language while logged in we update both. On
  /// login we mirror this back to the cookie so the choice follows the
  /// user across devices/browsers. Null until first explicit selection.
  preferredLanguage String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  sites               Site[]
  orders              Order[]
  domains             Domain[]
  templates           Template[]
  creditTransactions  CreditTransaction[]
  supportThread       SupportThread?
  /// Marketplace integrations are owned at the User level — not tied to a
  /// specific homenshop site. A seller can connect Coupang/Shopify/etc
  /// independently of any individual storefront they may also operate.
  marketplaceIntegrations MarketplaceIntegration[]
  customers           Customer[]

  @@index([email])
  @@index([shopId])
}

enum UserRole {
  ADMIN
  RESELLER
  MEMBER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// ============================================
// Sites (replaces SQLite per-user DBs)
// ============================================

model Site {
  id              String    @id @default(cuid())
  userId          String
  shopId          String    @unique
  name            String
  description     String?   @db.Text
  defaultLanguage String    @default("ko")
  languages       String[]  @default(["ko"])
  templateId      String?
  templatePath    String?
  headerHtml      String?   @db.Text
  menuHtml        String?   @db.Text
  footerHtml      String?   @db.Text
  cssText         String?   @db.Text
  published          Boolean   @default(false)
  accountType        String    @default("free")
  expiresAt          DateTime?
  googleAnalyticsId  String?
  googleVerification String?
  productSettings    Json?
  /// Email address the contact form sends to. Falls back to site owner's
  /// User.email when not set. Stored per-site so one user can operate
  /// multiple sites with different inbox destinations.
  contactEmail       String?
  /// Public business contact data used for SEO/JSON-LD (Organization
  /// schema), NOT for form submission routing. Separate from contactEmail
  /// because the public-facing business email (hanmail.net) often differs
  /// from the admin's internal login email.
  publicEmail        String?
  publicPhone        String?
  publicAddress      String?   @db.Text
  /// Absolute URL to a brand logo, used for JSON-LD Organization.logo
  /// and as an og:image fallback.
  logoUrl            String?
  /// Extended SEO/JSON-LD metadata bag. Currently supports keys:
  ///   · alternateName     — organization's alternate name
  ///   · slogan            — short business slogan
  ///   · foundingDate      — ISO date (e.g. "2001-01-01")
  ///   · areaServed        — string or string[]
  ///   · sameAs            — string[] of external identity URLs
  ///   · keywords          — comma-separated site-wide keywords
  ///   · businessType      — schema.org Organization subtype
  ///                         ("LocalBusiness" / "Store" / etc.)
  /// Free-form JSON lets new GEO/SEO fields land without migrations.
  seoMeta            Json?
  /// true = a hidden "template storage" site created by save-from-site.
  /// Filtered out of all user/admin site listings, site count limits, etc.
  /// Only reachable via Template.demoSiteId → 디자인 수정.
  isTemplateStorage  Boolean   @default(false)
  /// Last expiration-reminder milestone (7/3/1/0 days) sent to the owner.
  /// Set by /api/cron/expiration-reminders so we don't spam the same email
  /// twice for the same milestone. Reset to null when expiresAt is extended.
  lastReminderDay    Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages                   Page[]
  products                Product[]
  boardCategories         BoardCategory[]
  boardPosts              BoardPost[]
  boardPlugins            BoardPlugin[]
  productCategories       ProductCategory[]
  productPlugins          ProductPlugin[]
  domains                 Domain[]
  hmfTranslations         SiteHmf[]
  orders                  Order[]
  customers               Customer[]
  marketplaceIntegrations MarketplaceIntegration[]

  @@index([userId])
  @@index([isTemplateStorage])
}

model SiteHmf {
  id         String  @id @default(cuid())
  siteId     String
  lang       String
  headerHtml String? @db.Text
  menuHtml   String? @db.Text
  footerHtml String? @db.Text

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, lang])
  @@index([siteId])
}

model Page {
  id             String   @id @default(cuid())
  siteId         String
  title          String
  slug           String
  lang           String   @default("ko")
  content        Json?
  css            String?  @db.Text
  sortOrder      Int      @default(0)
  isHome         Boolean  @default(false)
  parentId       String?
  depth          String   @default("01")
  showInMenu     Boolean  @default(true)
  menuTitle      String?
  menuType       String   @default("page")
  externalUrl    String?
  seoTitle       String?
  seoDescription String?  @db.Text
  seoKeywords    String?
  ogImage        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  site     Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent   Page?  @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Page[] @relation("PageHierarchy")

  @@unique([siteId, slug, lang])
  @@index([siteId, lang])
  @@index([parentId])
}

// ============================================
// E-Commerce
// ============================================

model Product {
  id            String        @id @default(cuid())
  siteId        String
  legacyId      Int?
  lang          String        @default("ko")
  name          String
  description   String?       @db.Text
  price         Int
  salePrice     Int?
  stock         Int           @default(0)
  category      String?
  images        Json?
  photos        String?       @db.Text
  specification String?       @db.Text
  status        ProductStatus @default(ACTIVE)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  site            Site                    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  channelMappings ProductChannelMapping[]

  @@unique([siteId, legacyId])
  @@index([siteId])
  @@index([category])
}

enum ProductStatus {
  ACTIVE
  HIDDEN
  SOLDOUT
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  /// Site this order belongs to. Null for CREDIT_PACK / SUBSCRIPTION
  /// (which are platform-level purchases not tied to a specific storefront).
  siteId        String?
  orderNumber   String      @unique
  totalAmount   Int
  status        OrderStatus @default(PENDING)
  /// PRODUCT = physical/service order (default, backwards-compatible).
  /// CREDIT_PACK = AI credit top-up; on PAID → grants credits.packSize credits.
  /// SUBSCRIPTION = paid site plan (1yr/2yr/3yr); on PAID → extends Site.expiresAt.
  orderType     OrderType   @default(PRODUCT)
  /// Source channel — STOREFRONT for orders placed on a homenshop site,
  /// or one of the marketplace enums for orders synced from external platforms.
  channel       OrderChannel @default(STOREFRONT)
  /// FK to the MarketplaceIntegration this order was imported through.
  /// Null for STOREFRONT orders. Multiple integrations of the same channel
  /// can exist (multi-account), so dedupe is scoped by integrationId.
  integrationId String?
  /// External marketplace's order ID (Coupang's orderSheetCode, Shopify's
  /// order id, etc.). Combined with integrationId, must be unique to dedupe.
  externalOrderId String?
  /// Raw JSON snapshot of the external marketplace's order response, kept
  /// for audit/debugging and for replaying mappers when normalizers change.
  externalRawJson Json?
  /// Optional Customer reference (separates buyer identity from shipping
  /// info, enables repeat-customer analytics, GDPR-clean PII separation).
  customerId    String?
  /// For CREDIT_PACK orders: number of credits purchased.
  creditAmount  Int?
  /// For SUBSCRIPTION orders: number of months to extend the linked site.
  subscriptionMonths Int?
  /// For SUBSCRIPTION orders: id of the Site being extended.
  subscriptionSiteId String?
  paymentMethod String?
  paymentKey    String?
  shippingName  String?
  shippingPhone String?
  shippingAddr  String?     @db.Text
  shippingMemo  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  site               Site?               @relation(fields: [siteId], references: [id], onDelete: SetNull)
  integration        MarketplaceIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  creditTransactions CreditTransaction[]

  /// Dedupe within a marketplace account, not across the whole channel —
  /// two different Shopify shops can legitimately produce the same order id.
  @@unique([integrationId, externalOrderId], name: "integrationId_externalOrderId")
  @@index([userId])
  @@index([siteId])
  @@index([integrationId])
  @@index([orderNumber])
  @@index([orderType])
  @@index([channel])
  @@index([customerId])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPING
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderType {
  PRODUCT
  CREDIT_PACK
  SUBSCRIPTION
}

/// Channel (sales source) for an Order.
/// STOREFRONT = customer ordered directly from a homenshop-published site.
/// Other values represent orders synced FROM external marketplaces; the
/// adapter that imported the order sets this and writes externalOrderId.
enum OrderChannel {
  STOREFRONT
  SHOPIFY
  COUPANG
  AMAZON
  QOO10
  RAKUTEN
  TIKTOKSHOP
}

// ============================================
// AI Credits (immutable ledger)
// ============================================

/// Every credit change (grant, consumption, refund, admin adjust) is recorded
/// as a single CreditTransaction row. User.credits is a cached sum kept in
/// sync by src/lib/credits.ts. Never mutate User.credits directly — always
/// write a transaction via that module.
model CreditTransaction {
  id            String              @id @default(cuid())
  userId        String
  /// Signed amount: positive = grant/refund, negative = consumption.
  amount        Int
  /// User's total balance after applying this transaction (for audit).
  balanceAfter  Int
  kind          CreditTransactionKind
  /// For CREDIT_PACK purchases: the Order that paid for these credits.
  refOrderId    String?
  /// For AI consumption: which site this was for.
  refSiteId     String?
  /// AI model used (e.g., "claude-sonnet-4-6", "claude-haiku-4-5"). Audit only.
  aiModel       String?
  inputTokens   Int?
  outputTokens  Int?
  /// Human-readable description shown in user-facing history.
  description   String?             @db.Text
  /// Admin user ID for ADMIN_GRANT / ADMIN_DEBIT; null otherwise.
  adminUserId   String?
  createdAt     DateTime            @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [refOrderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([kind])
  @@index([refOrderId])
}

enum CreditTransactionKind {
  SIGNUP_BONUS
  MONTHLY_GRANT
  PURCHASE
  AI_SITE_CREATE
  AI_EDIT
  AI_OTHER
  REFUND
  ADMIN_GRANT
  ADMIN_DEBIT
}

// ============================================
// AI Image Search Cache
// ============================================

/// Maps a (keyword, orientation) tuple to a resolved image URL from Pexels
/// (or the fallback provider). Populated by /api/img on first lookup; reused
/// for ~30 days. Admin may purge rows to force re-fetch.
model ImageCache {
  id          String   @id @default(cuid())
  /// Normalized keyword: lowercased, trimmed, spaces collapsed.
  keyword     String
  /// "landscape" | "portrait" | "square" — matches Pexels orientation param.
  orientation String
  /// Resolved absolute URL the /api/img endpoint redirects to.
  url         String   @db.Text
  /// Attribution: photographer name & Pexels photo URL, for optional crediting.
  photographer String?
  sourceUrl   String?
  /// Image provider ("pexels" | "picsum" | "manual").
  provider    String   @default("pexels")
  /// Hit count — useful for tuning.
  hits        Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([keyword, orientation])
  @@index([keyword])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  /// Internal product reference. Null when the OrderItem represents a
  /// marketplace SKU that has not been mapped to a homenshop Product yet
  /// (we still want to import the order; mapping can happen later).
  productId String?
  /// External marketplace SKU/item identifier (Coupang's vendorItemId,
  /// Shopify's variant_id, etc.). Set for marketplace orders; null for
  /// native storefront orders that have a productId.
  externalSku String?
  /// Display name captured at import time so the UI is readable even if
  /// the seller hasn't mapped the SKU to a Product yet.
  externalName String?
  quantity  Int
  price     Int

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([externalSku])
}

// ============================================
// Customers (separated from shipping info on Order)
// ============================================

/// Repeat-customer entity. Splits buyer identity from per-order shipping
/// data so analytics and CS workflows can group orders by customer without
/// scanning shipping strings. Marketplace-imported orders resolve to
/// Customer when possible (marketplaces give us the buyer's email/handle).
///
/// Scoped at User level (siteId is optional — marketplace customers may
/// have no homenshop site association). Marketplace customers are further
/// scoped by integrationId, so two seller accounts on Qoo10 can have
/// separate customer bases even for the same buyer login id.
model Customer {
  id            String  @id @default(cuid())
  /// Owner — required. Marketplace customers always belong to one user
  /// regardless of whether they're tied to a homenshop site.
  userId        String
  /// Optional homenshop site association. Null for marketplace-only
  /// customers (no homenshop site involved).
  siteId        String?
  /// Channel where this customer first appeared. STOREFRONT for native
  /// orders, marketplace value for imported orders.
  channel       OrderChannel @default(STOREFRONT)
  /// FK to MarketplaceIntegration. Null for STOREFRONT customers.
  /// Two integrations of the same channel get separate Customer rows
  /// even for the same buyer (each seller account = independent base).
  integrationId String?
  /// Marketplace's buyer identifier (Coupang buyer login id, etc.).
  /// Null for STOREFRONT customers identified by email/phone only.
  externalId    String?
  email         String?
  phone         String?
  name          String?
  /// Free-form metadata bag (loyalty tier, marketplace VIP flag, etc.).
  meta          Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  site        Site?                   @relation(fields: [siteId], references: [id], onDelete: SetNull)
  integration MarketplaceIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  orders      Order[]

  /// Marketplace-side dedupe: one customer per (integration, externalId).
  /// STOREFRONT customers (integrationId null) skip this index — they're
  /// matched best-effort by email/phone in the importer.
  @@unique([integrationId, externalId], name: "integrationId_externalId")
  @@index([userId])
  @@index([siteId])
  @@index([integrationId])
  @@index([email])
  @@index([phone])
}

// ============================================
// Marketplace integration & product mapping
// ============================================

/// Marketplace integration — owned by a User, NOT a Site.
///
/// A seller may run a Coupang/Shopify/etc account that's completely
/// independent of any homenshop site they have. So MarketplaceIntegration
/// is scoped at User level. The optional `siteId` lets the seller
/// associate an integration with a specific homenshop site for unified
/// inventory/customer management — but it's not required.
///
/// Multiple rows per (user, channel) ARE allowed — sellers commonly run
/// several seller accounts on the same marketplace (e.g. one Qoo10 account
/// for beauty products, another for food). Each row represents one
/// account, with its own credentials, label, and order stream.
///
/// Credentials are AES-256-GCM encrypted JSON blobs (see src/lib/secrets.ts).
model MarketplaceIntegration {
  id          String           @id @default(cuid())
  /// Owner of the integration. Required.
  userId      String
  /// Optional association with a homenshop site (for inventory/customer
  /// linking). Null = standalone marketplace, no homenshop site involved.
  siteId      String?
  channel     OrderChannel
  /// Human-readable label set by the seller to distinguish multiple
  /// accounts on the same marketplace ("뷰티 계정", "식품 계정" etc.).
  /// Required — UI prompts for it on every connect/edit.
  label       String
  /// Adapter-supplied display name (Shopify shop URL, Coupang vendor name).
  /// Useful when the human label is empty or duplicated. Set during OAuth
  /// callback / verifyCredentials, not by the user.
  displayName String?
  /// Encrypted JSON: marketplace-specific credentials (access token,
  /// refresh token, vendorId, secret, etc.). Decrypted via decryptJson()
  /// only at the moment of API call — never logged.
  credentials String           @db.Text
  status      IntegrationStatus @default(DISCONNECTED)
  /// Last successful sync poll (or webhook receive). Drives the cron's
  /// "sync since X" cursor for marketplaces that lack push webhooks.
  lastSyncAt  DateTime?
  /// Most recent error string from a failed sync, surfaced in the
  /// integrations dashboard so the seller can act on token expiry etc.
  lastError   String?          @db.Text
  /// Marketplace-specific config (region, currency, fulfilment policy).
  config      Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  site      Site?                   @relation(fields: [siteId], references: [id], onDelete: SetNull)
  orders    Order[]
  customers Customer[]
  productMappings ProductChannelMapping[]

  @@index([userId, channel])
  @@index([siteId, channel])
  @@index([channel])
  @@index([status])
}

enum IntegrationStatus {
  DISCONNECTED
  ACTIVE
  ERROR
  PAUSED
}

/// Maps a homenshop Product to a marketplace SKU per integration.
///
/// Scoped by integrationId because the same internal Product can be
/// listed on multiple seller accounts (e.g. one product sold via two
/// Qoo10 stores) with different SKUs. The same SKU could even legitimately
/// appear in two different seller accounts on the same marketplace and
/// refer to different products (vendor-specific SKU spaces).
model ProductChannelMapping {
  id                String       @id @default(cuid())
  productId         String
  /// FK to MarketplaceIntegration. Each (product, integration) pair has
  /// at most one mapping; one product can have many mappings (one per
  /// connected account).
  integrationId     String
  channel           OrderChannel
  /// External SKU as it appears in marketplace order items.
  externalSku       String
  /// External product/listing ID (separate from SKU on marketplaces that
  /// distinguish, e.g. Shopify product_id vs variant_id).
  externalProductId String?
  /// Last time inventory/price was pushed to the marketplace.
  lastSyncedAt      DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  product     Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  integration MarketplaceIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalSku], name: "integrationId_externalSku")
  @@unique([productId, integrationId], name: "productId_integrationId")
  @@index([productId])
  @@index([integrationId])
  @@index([channel])
}

// ============================================
// Domains & Resellers
// ============================================

model Domain {
  id         String       @id @default(cuid())
  domain     String       @unique
  siteId     String
  userId     String
  status     DomainStatus @default(PENDING)
  sslEnabled Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([domain])
}

enum DomainStatus {
  PENDING
  ACTIVE
  EXPIRED
}

model Reseller {
  id        String  @id @default(cuid())
  domain    String  @unique
  siteName  String
  logo      String?
  copyright String?
  analytics String? @db.Text
  isActive  Boolean @default(true)

  @@index([domain])
}

// ============================================
// Templates
// ============================================

model Template {
  id           String   @id @default(cuid())
  legacyUid    Int?     @unique
  userId       String?
  name         String
  path         String   @unique
  thumbnailUrl String?
  category     String?
  price        Int      @default(0)
  keywords     String?
  description  String?  @db.Text
  demoSiteId   String?
  headerHtml   String?  @db.Text
  menuHtml     String?  @db.Text
  footerHtml   String?  @db.Text
  cssText      String?  @db.Text
  /// Snapshot of Page rows at save time (array of {slug,title,content,lang,sortOrder,isHome,showInMenu}).
  /// Takes precedence over disk-based parsing when present.
  pagesSnapshot Json?
  /// false = private to owner ("나의 템플릿"), true = visible to everyone ("공개 템플릿").
  /// Public templates with a userId are user-contributed; null userId is system-authored.
  isPublic     Boolean  @default(false)
  isActive     Boolean  @default(true)
  /// true = built mobile-responsive (single layout that flows). false = fixed desktop
  /// width (legacy templates that need a separate mobile layout). Drives the badge
  /// on the template list and the mobile-mode toggle in the design editor.
  isResponsive Boolean  @default(false)
  clicks       Int      @default(0)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([category])
  @@index([isActive])
  @@index([isPublic])
}

// ============================================
// Boards (Community / Notice)
// ============================================

model BoardCategory {
  id         String @id @default(cuid())
  siteId     String
  legacyId   Int?
  lang       String @default("ko")
  name       String
  defaultKey Int    @default(0)
  replyMode  Int    @default(2)
  writeMode  Int    @default(2)
  rowsPerPage Int   @default(20)
  titleLen   Int    @default(20)
  imgWidth   Int    @default(100)
  imgHeight  Int    @default(96)
  listStyle  Int    @default(0)

  site  Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  posts BoardPost[]

  @@unique([siteId, legacyId, lang])
  @@index([siteId, lang])
}

model BoardPost {
  id         String   @id @default(cuid())
  siteId     String
  categoryId String?
  legacyId   Int?
  lang       String   @default("ko")
  author     String
  title      String
  content    String   @db.Text
  photos     String?  @db.Text
  views      Int      @default(0)
  isNotice   Boolean  @default(false)
  isPublic   Boolean  @default(true)
  parentId   String?
  regdate    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  site     Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category BoardCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parent   BoardPost?     @relation("PostReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  BoardPost[]    @relation("PostReplies")
  comments BoardComment[]

  @@unique([siteId, legacyId])
  @@index([siteId, categoryId])
  @@index([categoryId])
  @@index([parentId])
}

model BoardComment {
  id        String   @id @default(cuid())
  postId    String
  author    String
  content   String   @db.Text
  parentId  String?
  createdAt DateTime @default(now())

  post     BoardPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent   BoardComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  BoardComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([parentId])
}

model BoardPlugin {
  id           String @id @default(cuid())
  siteId       String
  page         String
  divId        String
  categoryId   String?
  legacyCatId  Int?
  nums         Int    @default(5)
  titleLen     Int    @default(20)
  dateStyle    String @default("0")
  displayStyle Int    @default(0)
  imgWidth     Int    @default(150)
  imgHeight    Int    @default(100)
  skinFile     String?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, page, divId])
  @@index([siteId, page])
}

model ProductCategory {
  id         String @id @default(cuid())
  siteId     String
  legacyId   Int?
  lang       String @default("ko")
  name       String
  defaultKey Int    @default(0)
  parentLegacyId Int?
  depth      Int    @default(0)
  listStyle  Int    @default(0)
  rows       Int    @default(9)
  imgWidth   Int    @default(80)
  imgHeight  Int    @default(80)
  titleLen   Int    @default(30)
  textLen    Int    @default(0)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, legacyId, lang])
  @@index([siteId, lang])
}

model ProductPlugin {
  id           String @id @default(cuid())
  siteId       String
  lang         String @default("ko")
  page         String
  divId        String
  legacyCatId  Int?
  nums         Int    @default(7)
  titleLen     Int    @default(38)
  imgWidth     Int    @default(128)
  imgHeight    Int    @default(125)
  skinFile     String?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, lang, page, divId])
  @@index([siteId, lang, page])
}

// ============================================
// Password Reset
// ============================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime

  @@index([resetAt])
}

/// Records every master-password login. Exists so that during the test/renewal
/// phase, any abuse of the debug backdoor is fully traceable.
model MasterLoginAudit {
  id           String   @id @default(cuid())
  targetUserId String
  targetEmail  String
  ip           String
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([targetUserId])
  @@index([createdAt])
}

// ============================================
// Support chat — one thread per user, two-way messages with admin
// ============================================

/// Persistent conversation between a single user and the admin team.
/// One thread per user (lazily created on first message). `lastRead*At`
/// timestamps power unread badges on both sides — compared against the
/// most recent message from the OTHER side.
model SupportThread {
  id              String            @id @default(cuid())
  userId          String            @unique
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Last time the user opened the thread (null = never). Any admin
  /// message with createdAt > this is unread for the user.
  lastUserReadAt  DateTime?
  /// Last time an admin opened the thread. Any user message with
  /// createdAt > this is unread on the admin side.
  lastAdminReadAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  messages        SupportMessage[]

  @@index([updatedAt])
}

enum SupportSender {
  USER
  ADMIN
}

model SupportMessage {
  id        String         @id @default(cuid())
  threadId  String
  thread    SupportThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    SupportSender
  /// Admin user id when sender=ADMIN (for audit / multi-admin future).
  /// Null when sender=USER. Not a FK to avoid tying deletion.
  adminUserId String?
  body      String         @db.Text
  createdAt DateTime       @default(now())

  @@index([threadId, createdAt])
}

/// Inbound emails received via Resend Receiving (help@homenshop.com etc.).
model InboundEmail {
  id          String   @id @default(cuid())
  resendId    String?  @unique
  fromEmail   String
  fromName    String?
  toEmail     String
  cc          String?
  subject     String?
  text        String?  @db.Text
  html        String?  @db.Text
  headers     Json?
  attachments Json?
  forwarded   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([toEmail])
  @@index([createdAt])
}
