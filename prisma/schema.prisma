generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Auth (NextAuth.js / Auth.js)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// System Settings (key-value)
// ============================================

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ============================================
// Users & Members
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  phone         String?
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(MEMBER)
  status        UserStatus @default(ACTIVE)
  shopId        String?   @unique
  /// Cached AI credit balance. Authoritative source is sum(CreditTransaction.amount).
  /// Kept in sync by src/lib/credits.ts — never write outside that module.
  credits       Int       @default(0)
  /// Timestamp of last monthly auto-grant (for paid plans). Null = never granted.
  lastMonthlyGrantAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  sites               Site[]
  orders              Order[]
  domains             Domain[]
  templates           Template[]
  creditTransactions  CreditTransaction[]

  @@index([email])
  @@index([shopId])
}

enum UserRole {
  ADMIN
  RESELLER
  MEMBER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// ============================================
// Sites (replaces SQLite per-user DBs)
// ============================================

model Site {
  id              String    @id @default(cuid())
  userId          String
  shopId          String    @unique
  name            String
  description     String?   @db.Text
  defaultLanguage String    @default("ko")
  languages       String[]  @default(["ko"])
  templateId      String?
  templatePath    String?
  headerHtml      String?   @db.Text
  menuHtml        String?   @db.Text
  footerHtml      String?   @db.Text
  cssText         String?   @db.Text
  published          Boolean   @default(false)
  accountType        String    @default("free")
  expiresAt          DateTime?
  googleAnalyticsId  String?
  googleVerification String?
  productSettings    Json?
  /// Email address the contact form sends to. Falls back to site owner's
  /// User.email when not set. Stored per-site so one user can operate
  /// multiple sites with different inbox destinations.
  contactEmail       String?
  /// Public business contact data used for SEO/JSON-LD (Organization
  /// schema), NOT for form submission routing. Separate from contactEmail
  /// because the public-facing business email (hanmail.net) often differs
  /// from the admin's internal login email.
  publicEmail        String?
  publicPhone        String?
  publicAddress      String?   @db.Text
  /// Absolute URL to a brand logo, used for JSON-LD Organization.logo
  /// and as an og:image fallback.
  logoUrl            String?
  /// Extended SEO/JSON-LD metadata bag. Currently supports keys:
  ///   · alternateName     — organization's alternate name
  ///   · slogan            — short business slogan
  ///   · foundingDate      — ISO date (e.g. "2001-01-01")
  ///   · areaServed        — string or string[]
  ///   · sameAs            — string[] of external identity URLs
  ///   · keywords          — comma-separated site-wide keywords
  ///   · businessType      — schema.org Organization subtype
  ///                         ("LocalBusiness" / "Store" / etc.)
  /// Free-form JSON lets new GEO/SEO fields land without migrations.
  seoMeta            Json?
  /// true = a hidden "template storage" site created by save-from-site.
  /// Filtered out of all user/admin site listings, site count limits, etc.
  /// Only reachable via Template.demoSiteId → 디자인 수정.
  isTemplateStorage  Boolean   @default(false)
  /// Last expiration-reminder milestone (7/3/1/0 days) sent to the owner.
  /// Set by /api/cron/expiration-reminders so we don't spam the same email
  /// twice for the same milestone. Reset to null when expiresAt is extended.
  lastReminderDay    Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages             Page[]
  products          Product[]
  boardCategories   BoardCategory[]
  boardPosts        BoardPost[]
  boardPlugins      BoardPlugin[]
  productCategories ProductCategory[]
  productPlugins    ProductPlugin[]
  domains           Domain[]
  hmfTranslations   SiteHmf[]

  @@index([userId])
  @@index([isTemplateStorage])
}

model SiteHmf {
  id         String  @id @default(cuid())
  siteId     String
  lang       String
  headerHtml String? @db.Text
  menuHtml   String? @db.Text
  footerHtml String? @db.Text

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, lang])
  @@index([siteId])
}

model Page {
  id             String   @id @default(cuid())
  siteId         String
  title          String
  slug           String
  lang           String   @default("ko")
  content        Json?
  css            String?  @db.Text
  sortOrder      Int      @default(0)
  isHome         Boolean  @default(false)
  parentId       String?
  depth          String   @default("01")
  showInMenu     Boolean  @default(true)
  menuTitle      String?
  menuType       String   @default("page")
  externalUrl    String?
  seoTitle       String?
  seoDescription String?  @db.Text
  seoKeywords    String?
  ogImage        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  site     Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent   Page?  @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Page[] @relation("PageHierarchy")

  @@unique([siteId, slug, lang])
  @@index([siteId, lang])
  @@index([parentId])
}

// ============================================
// E-Commerce
// ============================================

model Product {
  id            String        @id @default(cuid())
  siteId        String
  legacyId      Int?
  lang          String        @default("ko")
  name          String
  description   String?       @db.Text
  price         Int
  salePrice     Int?
  stock         Int           @default(0)
  category      String?
  images        Json?
  photos        String?       @db.Text
  specification String?       @db.Text
  status        ProductStatus @default(ACTIVE)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  site       Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([siteId, legacyId])
  @@index([siteId])
  @@index([category])
}

enum ProductStatus {
  ACTIVE
  HIDDEN
  SOLDOUT
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  orderNumber   String      @unique
  totalAmount   Int
  status        OrderStatus @default(PENDING)
  /// PRODUCT = physical/service order (default, backwards-compatible).
  /// CREDIT_PACK = AI credit top-up; on PAID → grants credits.packSize credits.
  /// SUBSCRIPTION = paid site plan (1yr/2yr/3yr); on PAID → extends Site.expiresAt.
  orderType     OrderType   @default(PRODUCT)
  /// For CREDIT_PACK orders: number of credits purchased.
  creditAmount  Int?
  /// For SUBSCRIPTION orders: number of months to extend the linked site.
  subscriptionMonths Int?
  /// For SUBSCRIPTION orders: id of the Site being extended.
  subscriptionSiteId String?
  paymentMethod String?
  paymentKey    String?
  shippingName  String?
  shippingPhone String?
  shippingAddr  String?     @db.Text
  shippingMemo  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  items              OrderItem[]
  creditTransactions CreditTransaction[]

  @@index([userId])
  @@index([orderNumber])
  @@index([orderType])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPING
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderType {
  PRODUCT
  CREDIT_PACK
  SUBSCRIPTION
}

// ============================================
// AI Credits (immutable ledger)
// ============================================

/// Every credit change (grant, consumption, refund, admin adjust) is recorded
/// as a single CreditTransaction row. User.credits is a cached sum kept in
/// sync by src/lib/credits.ts. Never mutate User.credits directly — always
/// write a transaction via that module.
model CreditTransaction {
  id            String              @id @default(cuid())
  userId        String
  /// Signed amount: positive = grant/refund, negative = consumption.
  amount        Int
  /// User's total balance after applying this transaction (for audit).
  balanceAfter  Int
  kind          CreditTransactionKind
  /// For CREDIT_PACK purchases: the Order that paid for these credits.
  refOrderId    String?
  /// For AI consumption: which site this was for.
  refSiteId     String?
  /// AI model used (e.g., "claude-sonnet-4-6", "claude-haiku-4-5"). Audit only.
  aiModel       String?
  inputTokens   Int?
  outputTokens  Int?
  /// Human-readable description shown in user-facing history.
  description   String?             @db.Text
  /// Admin user ID for ADMIN_GRANT / ADMIN_DEBIT; null otherwise.
  adminUserId   String?
  createdAt     DateTime            @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [refOrderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([kind])
  @@index([refOrderId])
}

enum CreditTransactionKind {
  SIGNUP_BONUS
  MONTHLY_GRANT
  PURCHASE
  AI_SITE_CREATE
  AI_EDIT
  AI_OTHER
  REFUND
  ADMIN_GRANT
  ADMIN_DEBIT
}

// ============================================
// AI Image Search Cache
// ============================================

/// Maps a (keyword, orientation) tuple to a resolved image URL from Pexels
/// (or the fallback provider). Populated by /api/img on first lookup; reused
/// for ~30 days. Admin may purge rows to force re-fetch.
model ImageCache {
  id          String   @id @default(cuid())
  /// Normalized keyword: lowercased, trimmed, spaces collapsed.
  keyword     String
  /// "landscape" | "portrait" | "square" — matches Pexels orientation param.
  orientation String
  /// Resolved absolute URL the /api/img endpoint redirects to.
  url         String   @db.Text
  /// Attribution: photographer name & Pexels photo URL, for optional crediting.
  photographer String?
  sourceUrl   String?
  /// Image provider ("pexels" | "picsum" | "manual").
  provider    String   @default("pexels")
  /// Hit count — useful for tuning.
  hits        Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([keyword, orientation])
  @@index([keyword])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ============================================
// Domains & Resellers
// ============================================

model Domain {
  id         String       @id @default(cuid())
  domain     String       @unique
  siteId     String
  userId     String
  status     DomainStatus @default(PENDING)
  sslEnabled Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([domain])
}

enum DomainStatus {
  PENDING
  ACTIVE
  EXPIRED
}

model Reseller {
  id        String  @id @default(cuid())
  domain    String  @unique
  siteName  String
  logo      String?
  copyright String?
  analytics String? @db.Text
  isActive  Boolean @default(true)

  @@index([domain])
}

// ============================================
// Templates
// ============================================

model Template {
  id           String   @id @default(cuid())
  legacyUid    Int?     @unique
  userId       String?
  name         String
  path         String   @unique
  thumbnailUrl String?
  category     String?
  price        Int      @default(0)
  keywords     String?
  description  String?  @db.Text
  demoSiteId   String?
  headerHtml   String?  @db.Text
  menuHtml     String?  @db.Text
  footerHtml   String?  @db.Text
  cssText      String?  @db.Text
  /// Snapshot of Page rows at save time (array of {slug,title,content,lang,sortOrder,isHome,showInMenu}).
  /// Takes precedence over disk-based parsing when present.
  pagesSnapshot Json?
  /// false = private to owner ("나의 템플릿"), true = visible to everyone ("공개 템플릿").
  /// Public templates with a userId are user-contributed; null userId is system-authored.
  isPublic     Boolean  @default(false)
  isActive     Boolean  @default(true)
  clicks       Int      @default(0)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([category])
  @@index([isActive])
  @@index([isPublic])
}

// ============================================
// Boards (Community / Notice)
// ============================================

model BoardCategory {
  id         String @id @default(cuid())
  siteId     String
  legacyId   Int?
  lang       String @default("ko")
  name       String
  defaultKey Int    @default(0)
  replyMode  Int    @default(2)
  writeMode  Int    @default(2)
  rowsPerPage Int   @default(20)
  titleLen   Int    @default(20)
  imgWidth   Int    @default(100)
  imgHeight  Int    @default(96)
  listStyle  Int    @default(0)

  site  Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  posts BoardPost[]

  @@unique([siteId, legacyId, lang])
  @@index([siteId, lang])
}

model BoardPost {
  id         String   @id @default(cuid())
  siteId     String
  categoryId String?
  legacyId   Int?
  lang       String   @default("ko")
  author     String
  title      String
  content    String   @db.Text
  photos     String?  @db.Text
  views      Int      @default(0)
  isNotice   Boolean  @default(false)
  isPublic   Boolean  @default(true)
  parentId   String?
  regdate    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  site     Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category BoardCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parent   BoardPost?     @relation("PostReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  BoardPost[]    @relation("PostReplies")
  comments BoardComment[]

  @@unique([siteId, legacyId])
  @@index([siteId, categoryId])
  @@index([categoryId])
  @@index([parentId])
}

model BoardComment {
  id        String   @id @default(cuid())
  postId    String
  author    String
  content   String   @db.Text
  parentId  String?
  createdAt DateTime @default(now())

  post     BoardPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent   BoardComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  BoardComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([parentId])
}

model BoardPlugin {
  id           String @id @default(cuid())
  siteId       String
  page         String
  divId        String
  categoryId   String?
  legacyCatId  Int?
  nums         Int    @default(5)
  titleLen     Int    @default(20)
  dateStyle    String @default("0")
  displayStyle Int    @default(0)
  imgWidth     Int    @default(150)
  imgHeight    Int    @default(100)
  skinFile     String?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, page, divId])
  @@index([siteId, page])
}

model ProductCategory {
  id         String @id @default(cuid())
  siteId     String
  legacyId   Int?
  lang       String @default("ko")
  name       String
  defaultKey Int    @default(0)
  parentLegacyId Int?
  depth      Int    @default(0)
  listStyle  Int    @default(0)
  rows       Int    @default(9)
  imgWidth   Int    @default(80)
  imgHeight  Int    @default(80)
  titleLen   Int    @default(30)
  textLen    Int    @default(0)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, legacyId, lang])
  @@index([siteId, lang])
}

model ProductPlugin {
  id           String @id @default(cuid())
  siteId       String
  lang         String @default("ko")
  page         String
  divId        String
  legacyCatId  Int?
  nums         Int    @default(7)
  titleLen     Int    @default(38)
  imgWidth     Int    @default(128)
  imgHeight    Int    @default(125)
  skinFile     String?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, lang, page, divId])
  @@index([siteId, lang, page])
}

// ============================================
// Password Reset
// ============================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime

  @@index([resetAt])
}

/// Records every master-password login. Exists so that during the test/renewal
/// phase, any abuse of the debug backdoor is fully traceable.
model MasterLoginAudit {
  id           String   @id @default(cuid())
  targetUserId String
  targetEmail  String
  ip           String
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([targetUserId])
  @@index([createdAt])
}

/// Inbound emails received via Resend Receiving (help@homenshop.com etc.).
model InboundEmail {
  id          String   @id @default(cuid())
  resendId    String?  @unique
  fromEmail   String
  fromName    String?
  toEmail     String
  cc          String?
  subject     String?
  text        String?  @db.Text
  html        String?  @db.Text
  headers     Json?
  attachments Json?
  forwarded   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([toEmail])
  @@index([createdAt])
}
